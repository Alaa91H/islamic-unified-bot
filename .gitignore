# ==============================================================
# .gitignore — Islamic Unified Bot
# Covers: Python, Pyrogram/Telegram sessions, Docker, pytest,
#         coverage, common IDEs, OS artefacts, secrets, logs.
# ==============================================================


# ---------------------------------------------------------------
# 🔐 Secrets & credentials  (NEVER commit these)
# ---------------------------------------------------------------
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx
secrets.json
secrets.yaml
secrets.yml
*_secret*
*_credentials*
*credentials*.json


# ---------------------------------------------------------------
# 📱 Telegram / Pyrogram session files
# ---------------------------------------------------------------
*.session
*.session-journal
sessions/


# ---------------------------------------------------------------
# 🐍 Python
# ---------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.pyw

# Byte-compiled / optimised / DLL files
*.so
*.egg
*.egg-info/
*.egg-link
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
MANIFEST

# Distribution / packaging
.Python
pip-wheel-metadata/
share/python-wheels/
*.whl
*.tar.gz
!requirements*.txt

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
pytest_cache/
nosetests.xml
test-results/
junit/

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# Profiling
*.prof
*.lprof


# ---------------------------------------------------------------
# 🌐 Virtual environments
# ---------------------------------------------------------------
venv/
env/
.venv/
.env/
ENV/
env.bak/
venv.bak/
.virtualenv/
.pyenv/
pyenv/


# ---------------------------------------------------------------
# 🐳 Docker
# ---------------------------------------------------------------
.dockerignore
docker-compose.override.yml
*.dockerignore


# ---------------------------------------------------------------
# 📦 Build artefacts
# ---------------------------------------------------------------
*.zip
*.tar
*.tar.gz
*.tar.bz2
*.tar.xz
*.rar
!*.zip.sha256            # checksums are fine to keep
version.py               # auto-generated by CI


# ---------------------------------------------------------------
# 📝 Logs & runtime data
# ---------------------------------------------------------------
logs/
*.log
*.log.*
log/
*.out
*.err
celerybeat-schedule
celerybeat.pid


# ---------------------------------------------------------------
# 🎵 Media & audio data (large binary files)
# ---------------------------------------------------------------
music/
azan_data/
*.mp3
*.mp4
*.ogg
*.opus
*.m4a
*.wav
*.flac
*.aac


# ---------------------------------------------------------------
# 🗄️ Databases
# ---------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal
*.db-journal


# ---------------------------------------------------------------
# 🔬 Security scan reports (generated by CI)
# ---------------------------------------------------------------
bandit-report.json
pip-audit.json
.secrets.baseline
safety-report.json
trivy-results.json
semgrep-results.json


# ---------------------------------------------------------------
# 🛠️ IDEs & editors
# ---------------------------------------------------------------

# VS Code
.vscode/
*.code-workspace
.history/

# JetBrains (PyCharm, IntelliJ, etc.)
.idea/
*.iml
*.iws
*.ipr
out/
.idea_modules/

# Vim / Neovim
*.swp
*.swo
*.swn
*~
.netrwhist
Session.vim
.vim/

# Emacs
*#
.#*
\#*#
*.elc
auto-save-list
tramp
.\#*

# Sublime Text
*.tmlanguage.cache
*.tmPreferences.cache
*.stTheme.cache
*.sublime-workspace
.sublime-clang/

# Eclipse
.project
.classpath
.settings/
.loadpath
.metadata

# Notepad++
npp_backup/


# ---------------------------------------------------------------
# 💻 Operating system artefacts
# ---------------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network\ Trash\ Folder
Temporary\ Items
.apdisk

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
.directory
.Trash-*
.nfs*


# ---------------------------------------------------------------
# 📡 Misc tools
# ---------------------------------------------------------------

# Jupyter
.ipynb_checkpoints/
profile_default/
ipython_config.py
*.ipynb

# Celery
celerybeat-schedule.db

# SageMath
*.sage.py

# Sphinx documentation
docs/_build/
docs/_static/
docs/_templates/

# mkdocs
/site/

# pyenv
.python-version

# pipenv
Pipfile.lock

# poetry
poetry.lock       # uncomment if you do NOT want lock file committed
# Pipfile

# pdm
.pdm.toml
.pdm-python
.pdm-build/

# Rope
.ropeproject

# dotenv loading cache
.env.*.local

# Translations
*.mo
*.pot

# node (unlikely but covers any frontend tools)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.yarn/

# Terraform (if infra-as-code is ever added)
.terraform/
*.tfstate
*.tfstate.*
